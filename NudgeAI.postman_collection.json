				{
					"name": "Login to Nudge API",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Automatically save token to collection variable",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"auth_token\", jsonData.token);",
									"    console.log(\"Token saved: \" + jsonData.token.substring(0, 30) + \"...\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@mk.com\",\n  \"password\": \"Testing123\"\n}"
						},
						"url": {
							"raw": "{{nudge_api_url}}/auth/login",
							"host": [
								"{{nudge_api_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Login to Nudge API to get JWT token. Token is automatically saved to collection variable 'auth_token' and used in subsequent AI Agent requests."
					},
