# API Keys Configuration
# Copy this file to .env and add your actual configuration

# Model Provider: 'gemini' or 'qwen'
MODEL_PROVIDER=gemini

# Model Name
# For Gemini: gemini-pro, gemini-1.5-pro, gemini-1.5-flash, etc.
# For Qwen: qwen-turbo, qwen-plus, qwen-max, etc.
MODEL_NAME=gemini-pro

# API Key (use the appropriate key for your chosen provider)
API_KEY=your-api-key-here

# Alternative: Separate API keys for each provider
# GEMINI_API_KEY=your-gemini-api-key-here
# QWEN_API_KEY=your-qwen-api-key-here
