# API Keys Configuration
# Copy this file to .env and add your actual configuration

# Model Provider: 'gemini' or 'qwen'
MODEL_PROVIDER=gemini

# Model Name
# For Gemini: gemini-pro, gemini-1.5-pro, gemini-1.5-flash, etc.
# For Qwen (Ollama Cloud): qwen2.5:latest, qwen2.5:7b, qwen2.5-coder:latest, etc.
MODEL_NAME=gemini-pro

# API Keys - Only set the key for your chosen provider
# If MODEL_PROVIDER=gemini, set GEMINI_API_KEY
# If MODEL_PROVIDER=qwen, set OLLAMA_API_KEY (for Ollama Cloud)
GEMINI_API_KEY=your-gemini-api-key-here
OLLAMA_API_KEY=your-ollama-api-key-here

# Nudge API Configuration
# Base URL for the Nudge task management API
NUDGE_API_BASE_URL=http://localhost:8080

# FastAPI Server Configuration
# Port for the AI Agent API server
PORT=8000
