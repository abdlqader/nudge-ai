# API Keys Configuration
# Copy this file to .env and add your actual configuration

# Model Provider: 'gemini' or 'qwen'
MODEL_PROVIDER=gemini

# Model Name
# For Gemini: gemini-pro, gemini-1.5-pro, gemini-1.5-flash, etc.
# For Qwen: qwen-turbo, qwen-plus, qwen-max, etc.
MODEL_NAME=gemini-pro

# API Key (use the appropriate key for your chosen provider)
API_KEY=your-api-key-here

# Alternative: Separate API keys for each provider
# GEMINI_API_KEY=your-gemini-api-key-here
# QWEN_API_KEY=your-qwen-api-key-here

# Qwen Configuration (for local deployment)
# Base URL for Qwen API (OpenAI-compatible endpoint)
# Example: http://192.168.1.200:11434
QWEN_BASE_URL=http://192.168.1.200:11434

# Use native Ollama client (recommended for local Ollama)
# Set to 'true' to use ollama package, 'false' for OpenAI-compatible client
USE_OLLAMA_CLIENT=true

# Nudge API Configuration
# Base URL for the Nudge task management API
NUDGE_API_BASE_URL=http://localhost:8080

# FastAPI Server Configuration
# Port for the AI Agent API server
PORT=8000/v1
